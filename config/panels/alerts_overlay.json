{
  "id": "alerts_overlay",
  "type": "alerts_overlay",
  "focusable": true,

  "refresh": { "mode": "push", "topic": "rt/alerts/active", "fallbackPollMs": 1000 },


  "bindings": [
    { "id": "alerts", "source": "state", "key": "rt:alerts:active" },
    { "id": "focused_alert", "source": "state", "key": "rt:alerts:focused" }
  ],

  "actions": [
    { "intent": "alert.ack", "params": { "scope": "focused" } },
    { "intent": "alert.ack", "params": { "scope": "all_visible" } },
    { "intent": "alert.silence", "params": { "minutes": 10 } }
  ],

  "drivingMode": {
    "allowActions": ["alert.ack"]
  },

  "meta": {
    "purpose": "Cross-page alert UI. Must be safe while driving.",
    "title": "Alerts",
    "contract": {
      "requiredBindings": ["alerts"],
      "allowNull": ["focused_alert"]
    }
  }
}
