{
  "id": "node_health_summary",
  "type": "node_health_summary",
  "focusable": true,

  "refresh": { "mode": "poll", "intervalMs": 1000 },

  "bindings": [
    {"id": "nodes", "source": "api", "url": "./dev/nodes_health.json" },
    {"id": "controller", "source": "state", "key": "rt:node:rt-controller" },
    {"id":"radio","source":"state","key":"rt:node:rt-radio"},
    {"id":"display","source":"state","key":"rt:node:rt-display"},
    {"id": "wpsd", "source": "state", "key": "rt:node:rt-wpsd" }
  ],

  "actions": [
    { "intent": "host.status", "params": { "scope": "summary" } }
  ],

  "meta": {
    "purpose": "At-a-glance health of nodes/services."
  }
}
