[Unit]
Description=RollingThunder GPS/Env State Publisher
After=network.target
Wants=network.target

[Service]
Type=simple
User=spiff
WorkingDirectory=/opt/rollingthunder/nodes/rt-controller/services
ExecStart=/opt/rollingthunder/.venv/bin/python /opt/rollingthunder/services/gps_state_publisher.py
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
