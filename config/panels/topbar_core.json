{
  "id": "topbar_core",
  "type": "topbar_core",
  "focusable": false,

  "refresh": { "mode": "poll", "intervalMs": 1000 },

"bindings": [
  { "id": "sys_health", "source": "state", "key": "rt:system:health" }
],

  "meta": {
    "purpose": "Always-visible status bar (time, gps, alert indicator). No actions."
  }
}
