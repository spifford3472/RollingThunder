# RollingThunder radio configuration
# Node: rt-radio
# Radio: Yaesu FT-891 via DigiRig DR-891

RT_HAMLIB_MODEL=1036

RT_HAMLIB_BIND_HOST=127.0.0.1
RT_HAMLIB_PORT=4532

RT_RIG_DEVICE=/dev/serial/by-id/usb-Silicon_Labs_CP2105_Dual_USB_to_UART_Bridge_Controller_011F42E9-if00-port0

RT_RIG_BAUD=38400
RT_RIG_PTT_MODE=RIG

RT_HAMLIB_RETRY=5
RT_HAMLIB_TIMEOUT_MS=2000