{
  "id": "home",
  "order": 1,
  "title": "Home",

  "layout": {
    "top": ["topbar_core"],
    "middle": [
      ["controller_services_summary"],
      ["node_health_summary", "deploy_drift_summary"]
    ],
    "bottom": ["alerts_overlay"]
  },

  "requires": ["redis_state", "mqtt_bus", "gps_ingest"],
  "optional": ["logging", "node_health", "noaa_same", "meshtastic_c2"],

  "controls": {
    "allowedIntents": [
      "ui.page.next",
      "ui.page.prev",
      "ui.focus.next",
      "ui.focus.prev",
      "ui.ok",
      "ui.cancel",
      "alert.ack",
      "alert.silence",
      "host.status",
      "node.reboot",
      "radio.tune"
    ]
  },

  "focusPolicy": {
    "defaultPanel": "controller_services_summary",
    "rotation": ["controller_services_summary","node_health_summary"]
  },

  "meta": {
    "purpose": "Default safe landing page with alerts + system health."
  }
}
