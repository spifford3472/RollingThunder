{
  "id": "wpsd_status",
  "type": "wpsd_status",
  "interaction": {
    "browsable": false
  },
  "focusable": true,

  "refresh": { "mode": "push", "topic": "state.changed", "fallbackPollMs": 1500 },

  "bindings": [
    { "id": "rf_slots",  "source": "state", "key": "rt:wpsd:rf:slots" },
    { "id": "rf_recent", "source": "state", "key": "rt:wpsd:rf:recent" }
  ],

  "actions": [],

  "meta": {
    "title": "WPSD RF Status",
    "purpose": "DMR RF activity summary for TS1/TS2 and recent transmissions.",
    "flagBaseURL": "/proxy/wpsd",
    "contract": {
      "requiredBindings": ["rf_slots", "rf_recent"]
    }
  }
}
