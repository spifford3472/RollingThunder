#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
app_json="${repo_root}/config/app.json"

echo "[hook pre-push] running repo invariants..."
"${repo_root}/tools/rt_verify_repo.sh"

if ! git diff --quiet -- "${app_json}"; then
  echo "[hook pre-push] ERROR: config/app.json has uncommitted changes."
  echo "Run your build bump workflow, commit app.json, then push again."
  echo "How to Deploy"
  echo "======================"
  echo "tools/rt_bump_build.sh"
  echo "git add config/app.json <other files>"
  echo "git commit -m 'what did we change?'"
  echo "git push"
  echo "deploy/push_rt_xxxxx.sh"
  echo "======================"
  exit 1
fi

echo "[hook pre-push] OK"