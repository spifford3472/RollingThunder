{
  "id": "controller_services_summary",
  "type": "controller_services_summary",
  "interaction": {
    "browsable": true
  },
  "focusable": true,
  "refresh": { "mode": "push" },
  "bindings": [
    {
      "id": "controller_services",
      "source": "scan",
      "match": "rt:services:*",
      "limit": 200
    },
    {
      "id": "ui_browse",
      "source": "state",
      "key": "rt:ui:browse:controller_services_summary"
    }
  ],
  "meta": {
    "purpose": "Service list with browse scrolling (view-only; no restart)."
  }
}