{
  "schema": {
    "id": "rollingthunder.app",
    "version": "1.0.0",
    "compat": {
      "minReader": "1.0.0",
      "allowUnknownFields": true
    }
  },
  "runtimeVersion": {
    "major": 0,
    "minor": 37,
    "build": 6
  },
  "deploymentDefaults": {
    "fleet": "rollingthunder",
    "environment": "vehicle"
  },
  "globals": {
    "time": {
      "timezone": "America/New_York",
      "gpsIsAuthoritative": true
    },
    "state": {
      "redisUrl": "redis://127.0.0.1:6379",
      "namespace": "rt"
    },
    "bus": {
      "mqttUrl": "mqtt://127.0.0.1:1883",
      "topicRoot": "rt"
    },
    "api": {
      "controllerBaseUrl": "http://rt-controller.local:8787",
      "uiPollMs": 500
    },
    "defaults": {
      "serviceStartTimeoutMs": 4000,
      "serviceStopTimeoutMs": 3000,
      "healthPollMs": 2000
    },
    "safety": {
      "drivingMode": {
        "source": "gps_speed",
        "thresholdMph": 5
      },
      "noTextEntryWhenDriving": true
    }
  },
  "services": {
    "redis_state": {
      "id": "redis_state",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "redis_ping",
        "target": "globals.state.redisUrl",
        "staleAfterMs": 5000
      },
      "provides": [
        "state.core"
      ]
    },
    "mqtt_bus": {
      "id": "mqtt_bus",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "dependsOn": [
        "redis_state"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "mqtt_ping",
        "target": "globals.bus.mqttUrl",
        "staleAfterMs": 10000
      },
      "provides": [
        "bus.core"
      ]
    },
    "gps_ingest": {
      "id": "gps_ingest",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-gps-ingest.service"
      },
      "dependsOn": [
        "redis_state",
        "mqtt_bus"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:gps:fix",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 3000
      },
      "provides": [
        "state.gps.fix",
        "state.gps.time",
        "state.gps.speed"
      ],
      "consumes": []
    },
    "pota_nearby_parks": {
      "id": "pota_nearby_parks",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-pota-nearby-parks.service"
      },
      "dependsOn": [
        "redis_state",
        "gps_ingest"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:pota:nearby",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 5000
      },
      "provides": [
        "state.pota.nearby",
        "alerts.pota.nearby"
      ]
    },
    "pota_context_manager": {
      "id": "pota_context_manager",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-pota-context-manager.service"
      },
      "dependsOn": [
        "redis_state",
        "pota_nearby_parks"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:pota:ui:ssb:bands",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 5000
      },
      "provides": [
        "state.pota.context",
        "state.pota.ui.ssb.bands",
        "state.pota.ui.ssb.spots"
      ]
    },
    "logging": {
      "id": "logging",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "dependsOn": [
        "redis_state"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:logging:alive",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 10000
      },
      "provides": [
        "state.logging",
        "logs.events"
      ]
    },
    "node_health": {
      "id": "node_health",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "dependsOn": [
        "redis_state",
        "mqtt_bus"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "http_json",
        "target": "http://rt-controller.local:8787/health",
        "okRules": [
          {
            "path": "$.ok",
            "equals": true
          }
        ],
        "staleAfterMs": 5000
      },
      "provides": [
        "state.nodes.health"
      ]
    },
    "noaa_same": {
      "id": "noaa_same",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "dependsOn": [
        "redis_state",
        "mqtt_bus",
        "gps_ingest"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 5000,
          "maxBackoffMs": 60000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:noaa:decoder",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 15000
      },
      "provides": [
        "alerts.noaa",
        "state.noaa.station",
        "state.noaa.county"
      ]
    },
    "meshtastic_c2": {
      "id": "meshtastic_c2",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "dependsOn": [
        "redis_state",
        "mqtt_bus"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 5000,
          "maxBackoffMs": 60000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:meshtastic:link",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 30000
      },
      "permissions": {
        "default": "read_only",
        "allowListedSenders": [],
        "writeCapabilities": {
          "serviceControl": {
            "enabled": false,
            "allowServices": []
          },
          "pageChange": {
            "enabled": false,
            "allowPages": []
          }
        }
      },
      "rateLimits": {
        "statusPerMinute": 12,
        "alertsPerMinute": 6,
        "maxMessageBytes": 180
      },
      "provides": [
        "bus.meshtastic.status",
        "alerts.meshtastic"
      ]
    },
    "hf_radio_proxy": {
      "id": "hf_radio_proxy",
      "scope": "page_scoped",
      "ownerNode": "rt-radio",
      "dependsOn": [],
      "lifecycle": {
        "startPolicy": "onPageEnter",
        "stopPolicy": "onLastUserExit",
        "restartPolicy": {
          "mode": "never"
        }
      },
      "health": {
        "type": "http_json",
        "target": "http://rt-radio.local:8801/health",
        "okRules": [
          {
            "path": "$.ok",
            "equals": true
          }
        ],
        "staleAfterMs": 5000
      },
      "provides": [
        "state.hf.snapshot"
      ]
    },
    "wpsd_integration": {
      "id": "wpsd_integration",
      "scope": "page_scoped",
      "ownerNode": "external",
      "systemd": {
        "unit": "rt-wpsd-poller.service"
      },
      "lifecycle": {
        "startPolicy": "manualOnly",
        "stopPolicy": "onPageExit",
        "restartPolicy": {
          "mode": "never"
        }
      },
      "health": {
        "type": "external_api",
        "target": "http://rt-wpsd.local/",
        "staleAfterMs": 15000
      },
      "provides": [
        "state.dmr.snapshot"
      ]
    },
    "wpsd_log_ingestor": {
      "id": "wpsd_log_ingestor",
      "scope": "page_scoped",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-wpsd-log-ingestor.service"
      },
      "dependsOn": [
        "redis_state",
        "mqtt_bus"
      ],
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "onLastUserExit",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 15000
        }
      },
      "health": {
        "type": "state_freshness",
        "target": {
          "key": "rt:wpsd:rf:slots",
          "namespace": "globals.state.namespace"
        },
        "staleAfterMs": 8000
      },
      "provides": [
        "state.wpsd.rf"
      ]
    },
    "alerts_reconciler": {
      "id": "alerts_reconciler",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-alerts-reconciler.service"
      },
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "http_json",
        "target": "http://rt-controller.local:8787/alerts_health",
        "okRules": [
          {
            "path": "$.ok",
            "equals": true
          }
        ],
        "staleAfterMs": 5000
      },
      "provides": [
        "state.nodes.alerts_reconciler"
      ]
    },
    "service_state_publisher": {
      "id": "service_state_publisher",
      "scope": "always_on",
      "ownerNode": "rt-controller",
      "systemd": {
        "unit": "rt-service-state-publisher.service"
      },
      "lifecycle": {
        "startPolicy": "onBoot",
        "stopPolicy": "never",
        "restartPolicy": {
          "mode": "onFailure",
          "backoffMs": 2000,
          "maxBackoffMs": 30000
        }
      },
      "health": {
        "type": "http_json",
        "target": "http://rt-controller.local:8787/alerts_health",
        "okRules": [
          {
            "path": "$.ok",
            "equals": true
          }
        ],
        "staleAfterMs": 5000
      },
      "provides": [
        "state.nodes.service_state_publisher"
      ]
    }
  },
  "pages": {
    "include": [
      "pages.manifest.json"
    ]
  },
  "panels": {
    "include": [
      "panels.manifest.json"
    ]
  },
  "inputs": {
    "sources": {},
    "maps": []
  },
  "alerts": {
    "normalization": {},
    "dedup": {
      "rules": []
    },
    "routing": [],
    "acknowledgement": {},
    "rateLimits": {}
  },
  "meta": {
    "notes": "Skeleton only. Populate services/pages/panels next."
  },
  "bandOrder": [
    "160m",
    "80m",
    "60m",
    "40m",
    "30m",
    "20m",
    "17m",
    "15m",
    "12m",
    "10m",
    "6m"
  ],
  "bands": {
    "160m": {
      "low_mhz": 1.8,
      "high_mhz": 2.0
    },
    "80m": {
      "low_mhz": 3.5,
      "high_mhz": 4.0
    },
    "60m": {
      "low_mhz": 5.0,
      "high_mhz": 5.5
    },
    "40m": {
      "low_mhz": 7.0,
      "high_mhz": 7.3
    },
    "30m": {
      "low_mhz": 10.1,
      "high_mhz": 10.15
    },
    "20m": {
      "low_mhz": 14.0,
      "high_mhz": 14.35
    },
    "17m": {
      "low_mhz": 18.068,
      "high_mhz": 18.168
    },
    "15m": {
      "low_mhz": 21.0,
      "high_mhz": 21.45
    },
    "12m": {
      "low_mhz": 24.89,
      "high_mhz": 24.99
    },
    "10m": {
      "low_mhz": 28.0,
      "high_mhz": 29.7
    },
    "6m": {
      "low_mhz": 50.0,
      "high_mhz": 54.0
    }
  },
  "potaBandDefaults": {
    "160m": 1.9,
    "80m": 3.9,
    "60m": 5.357,
    "40m": 7.2,
    "30m": 10.12,
    "20m": 14.285,
    "17m": 18.14,
    "15m": 21.285,
    "12m": 24.95,
    "10m": 28.4
  }
}
