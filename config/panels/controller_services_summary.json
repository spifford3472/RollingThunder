// controller_services_summary.js
//
// Enhancement:
// - Windowed list: show at most 11 rows.
// - Browse mode cursor highlight (selected service).
// - Reacts to runtime events:
//    * rt-browse-delta {delta:+1/-1} to scroll/cursor
//    * rt-browse-ok to request a restart confirm modal
// - Panel stores browse state on container to survive refresh.
//
// Contract with runtime:
// - runtime sets slot.classList.add("rt-browse-mode") while in PANEL_BROWSE
// - runtime dispatches events on the slot element (not the body):
//      slot.dispatchEvent(new CustomEvent("rt-browse-delta", {detail:{delta}}))
//      slot.dispatchEvent(new CustomEvent("rt-browse-ok"))
//
// Contract with runtime modal:
// - panel dispatches bubbled event from the slot:
//      slot.dispatchEvent(new CustomEvent("rt-open-modal", { bubbles:true, detail:{...}}))

const WINDOW = 11;

function pillHtml(kind, label) {
  const cls =
    kind === "ok" ? "rt-pill ok" :
    kind === "warn" ? "rt-pill warn" :
    "rt-pill bad";
  return `<span class="${cls}">${label}</span>`;
}

function stateToPill(state) {
  const s = String(state || "").toLowerCase();
  if (s === "running" || s === "active") return pillHtml("ok", "RUN");
  if (s === "stopped" || s === "inactive") return pillHtml("warn", "STOP");
  if (s === "failed") return pillHtml("bad", "FAIL");
  if (s === "missing") return pillHtml("bad", "MISS");
  if (s === "unknown") return pillHtml("warn", "UNKN");
  if (!s) return pillHtml("warn", "N/A");
  return pillHtml("warn", s.slice(0, 5).toUpperCase());
}

function shouldShowService(svc) {
  const s = String(svc?.state || "").toLowerCase().trim();
  if (!s) return false;
  if (s === "unknown") return false;
  return true;
}

function ageSecFromMs(ms) {
  const n = Number(ms ?? NaN);
  if (!Number.isFinite(n) || n <= 0) return null;
  return Math.max(0, Math.floor((Date.now() - n) / 1000));
}

function fmtAge(ageSec) {
  if (ageSec == null) return "—";
  if (ageSec < 60) return `${ageSec}s`;
  const m = Math.floor(ageSec / 60);
  const s = ageSec % 60;
  return `${m}m${String(s).padStart(2, "0")}s`;
}

function startAgeTicker(container) {
  if (container.__rtAgeTimer) {
    try { clearInterval(container.__rtAgeTimer); } catch (_) {}
    container.__rtAgeTimer = null;
  }

  container.__rtAgeTimer = setInterval(() => {
    const cells = container.querySelectorAll("[data-rt-age-ms]");
    for (const el of cells) {
      const ms = el.getAttribute("data-rt-age-ms");
      const age = ageSecFromMs(ms);
      el.textContent = fmtAge(age);

      const tr = el.closest("tr");
      if (tr) {
        const stale = (age != null && age > 12);
        tr.classList.toggle("stale", stale);
      }
    }
  }, 1000);
}

function safeText(s) {
  return String(s ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function clamp(n, lo, hi) {
  n = Number(n);
  if (!Number.isFinite(n)) return lo;
  return Math.max(lo, Math.min(hi, n));
}

function ensureBrowseState(container) {
  if (!container.__rtBrowse) {
    container.__rtBrowse = { offset: 0, cursor: 0 };
  }
  if (typeof container.__rtBrowse.offset !== "number") container.__rtBrowse.offset = 0;
  if (typeof container.__rtBrowse.cursor !== "number") container.__rtBrowse.cursor = 0;
  return container.__rtBrowse;
}

function getSlotEl(container) {
  // container is bodyEl; slot is closest .rt-slot
  return container?.closest?.(".rt-slot") || null;
}

function isBrowseMode(container) {
  const slot = getSlotEl(container);
  return !!slot && slot.classList.contains("rt-browse-mode");
}

function normalizeAndSort(all) {
  const services = (Array.isArray(all) ? all : [])
    .filter(shouldShowService)
    .slice()
    .sort((a, b) => {
      const as = String(a?.id || a?.key || "");
      const bs = String(b?.id || b?.key || "");
      return as.localeCompare(bs);
    });

  return services.map((svc) => ({
    id: String(svc?.id || svc?.key || "unknown"),
    state: svc?.state ?? null,
    last_update_ms: svc?.last_update_ms ?? null,
  }));
}

function renderTable(container, services, browse) {
  const browsing = isBrowseMode(container);

  // Keep browse state valid relative to services length
  const n = services.length;
  if (n === 0) {
    browse.offset = 0;
    browse.cursor = 0;
  } else {
    browse.cursor = clamp(browse.cursor, 0, n - 1);
    browse.offset = clamp(browse.offset, 0, Math.max(0, n - WINDOW));
    // Ensure cursor is inside window
    if (browse.cursor < browse.offset) browse.offset = browse.cursor;
    if (browse.cursor >= browse.offset + WINDOW) browse.offset = browse.cursor - (WINDOW - 1);
    browse.offset = clamp(browse.offset, 0, Math.max(0, n - WINDOW));
  }

  const start = browse.offset;
  const end = Math.min(n, start + WINDOW);
  const slice = services.slice(start, end);

  const rows = slice.map((svc, i) => {
    const absoluteIndex = start + i;
    const selected = browsing && absoluteIndex === browse.cursor;

    const pill = stateToPill(svc.state);
    const ms = svc.last_update_ms ?? null;
    const ageTxt = fmtAge(ageSecFromMs(ms));
    const stale = (ageSecFromMs(ms) != null && ageSecFromMs(ms) > 12);

    const trCls = [
      "rt-row",
      stale ? "stale" : "",
      selected ? "rt-selected" : "",
    ].filter(Boolean).join(" ");

    // Optional left “cursor” glyph. Purely visual.
    const cursorGlyph = selected ? "▶" : "&nbsp;";

    return `
      <tr class="${trCls}" data-rt-svc-id="${safeText(svc.id)}" data-rt-idx="${absoluteIndex}">
        <td class="rt-cell-cursor">${cursorGlyph}</td>
        <td class="rt-cell-name">${safeText(svc.id)}</td>
        <td class="rt-cell-status">${pill}</td>
        <td class="rt-cell-age" data-rt-age-ms="${ms ?? ""}">${ageTxt}</td>
      </tr>
    `;
  }).join("");

  const more = n > WINDOW;
  const top = start;
  const bot = Math.max(0, n - end);

  container.innerHTML = `
    <div class="rt-table-wrap">
      <table class="rt-table rt-services">
        <thead>
          <tr>
            <th class="rt-th-cursor"></th>
            <th>Service</th>
            <th>Status</th>
            <th>Age</th>
          </tr>
        </thead>
        <tbody>
          ${
            rows ||
            `<tr><td colspan="4">No services</td></tr>`
          }
        </tbody>
      </table>

      ${
        more
          ? `<div class="rt-list-hint">
               <span>${top > 0 ? `▲ ${top} above` : ""}</span>
               <span>${bot > 0 ? `▼ ${bot} below` : ""}</span>
             </div>`
          : ``
      }
    </div>
  `;
}

function attachBrowseListenersOnce(container) {
  if (container.__rtBrowseBound) return;
  container.__rtBrowseBound = true;

  const slot = getSlotEl(container);
  if (!slot) return;

  slot.addEventListener("rt-browse-delta", (ev) => {
    const browse = ensureBrowseState(container);
    const delta = Number(ev?.detail?.delta ?? 0);
    if (!Number.isFinite(delta) || delta === 0) return;

    const services = Array.isArray(container.__rtLastServices) ? container.__rtLastServices : [];
    if (services.length === 0) return;

    // Cursor moves; window follows
    browse.cursor = clamp(browse.cursor + (delta > 0 ? 1 : -1), 0, services.length - 1);

    // Re-render immediately from cached data (no waiting for refresh tick)
    renderTable(container, services, browse);
  });

  slot.addEventListener("rt-browse-ok", () => {
    const services = Array.isArray(container.__rtLastServices) ? container.__rtLastServices : [];
    const browse = ensureBrowseState(container);
    if (services.length === 0) return;

    const idx = clamp(browse.cursor, 0, services.length - 1);
    const svc = services[idx];
    const svcId = svc?.id;
    if (!svcId) return;

    // Ask runtime to open a confirm modal (runtime-owned DOM, not wiped by refresh)
    slot.dispatchEvent(new CustomEvent("rt-open-modal", {
      bubbles: true,
      detail: {
        kind: "confirm",
        title: "Restart service?",
        body: `Restart '${svcId}' on rt-controller?`,
        confirmLabel: "Restart",
        cancelLabel: "Cancel",
        // Runtime will call these callbacks by emitting events back to the slot
        // (or it can handle action itself; see runtime.js section below)
        action: {
          intent: "service.restart",
          params: { service_id: svcId },
        }
      }
    }));
  });
}

export function renderControllerServicesSummary(container, panel, data) {
  attachBrowseListenersOnce(container);

  const all = Array.isArray(data?.controller_services) ? data.controller_services : [];
  const services = normalizeAndSort(all);

  // Cache last list for immediate re-render on browse deltas
  container.__rtLastServices = services;

  const browse = ensureBrowseState(container);

  // If not browsing, keep cursor pinned to top of window for now.
  // (If you want “remember last cursor” even when leaving browse, remove this.)
  if (!isBrowseMode(container)) {
    browse.offset = 0;
    browse.cursor = 0;
  }

  renderTable(container, services, browse);
  startAgeTicker(container);
}