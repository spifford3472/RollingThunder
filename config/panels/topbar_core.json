{
  "id": "topbar_core",
  "type": "topbar_core",
  "focusable": false,

  "refresh": { "mode": "poll", "intervalMs": 1000 },

  "refresh": { "mode": "poll", "intervalMs": 1000 },

  "bindings": [
    {"id": "clock", "source": "state", "key": "rt:gps:time" },
    {"id": "gps_fix", "source": "state", "key": "rt:gps:fix" },
    {"gps_speed": "nodes", "source": "state", "key": "rt:gps:speed" },
    {"active_alerts": "nodes", "source": "state", "key": "rt:alerts:active" }
  ],

  "meta": {
    "purpose": "Always-visible status bar (time, gps, alert indicator). No actions."
  }
}
